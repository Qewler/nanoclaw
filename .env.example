DISCORD_BOT_TOKEN=
ASSISTANT_HAS_OWN_NUMBER=
OPENAI_API_KEY=

# Home Assistant (home-assistant-manager skill)
# HASS_SERVER is the HA URL the container will use (hass-cli reads this).
# HASS_TOKEN is a long-lived access token from HA profile → Security.
# HA_HOST_IP is injected as --add-host homeassistant.local:<IP> so both
# the SSH target and HASS_SERVER resolve without mDNS inside the container.
HASS_SERVER=http://homeassistant.local:8123
HASS_TOKEN=
HA_HOST_IP=
